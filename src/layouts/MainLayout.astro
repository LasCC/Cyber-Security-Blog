---
import "../styles/base.css";

import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description: string;
  heroImage?: string;
  type?: "website" | "article";
  pubDate?: Date;
  updatedDate?: Date;
}

const { title, description, heroImage, type, pubDate, updatedDate } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {title} {description} image={heroImage} {type} {pubDate} {updatedDate} />
    <ClientRouter />
    <script is:inline>
