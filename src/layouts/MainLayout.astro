    </script>
  </head>
  <body class="bg-[#070707] text-stone-200">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-lime-500 focus:text-black focus:px-4 focus:py-2 focus:rounded">Skip to content</a>
