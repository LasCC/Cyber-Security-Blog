---
import { getCollection } from "astro:content";
import FeaturedPosts from "../components/FeaturedPosts.astro";
import RecentPosts from "../components/RecentPosts.astro";
import SearchPosts from "../components/SearchPosts.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../config";
import MainLayout from "../layouts/MainLayout.astro";

const posts = await getCollection("blog");
const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))].sort();
const postCount = posts.length;

const categoryColors: Record<string, string> = {
  THM: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20 hover:bg-emerald-500/20",
  "Malware Analysis": "bg-red-500/10 text-red-400 border-red-500/20 hover:bg-red-500/20",
  "Reverse Engineering": "bg-purple-500/10 text-purple-400 border-purple-500/20 hover:bg-purple-500/20",
  XSS: "bg-amber-500/10 text-amber-400 border-amber-500/20 hover:bg-amber-500/20",
  CEH: "bg-blue-500/10 text-blue-400 border-blue-500/20 hover:bg-blue-500/20",
};
---

<MainLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <div class="py-6">
    <div class="pt-16 pb-8">
      <h1
        class="text-4xl max-w-lg font-medium bg-linear-to-r from-slate-700 to-slate-500 dark:from-slate-100 dark:to-slate-400 inline-block text-transparent bg-clip-text"
      >
        Ludovic COULON
      </h1>
      <p
        class="mt-4 text-zinc-600 dark:text-zinc-400 max-w-2xl leading-relaxed"
      >
        Aspiring DFIR Analyst and experienced CSIRT Analyst, dedicated to
        investigating and mitigating cybersecurity incidents and protecting
        organizations from cyber threats.
      </p>
      <div class="flex items-center gap-4 mt-5 text-sm text-zinc-500">
        <span class="flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-400 dark:text-zinc-600">
            <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
          </svg>
          {postCount} articles
        </span>
        <span class="flex items-center gap-1.5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-zinc-400 dark:text-zinc-600">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
            <line x1="7" y1="7" x2="7.01" y2="7" />
          </svg>
          {categories.length} categories
        </span>
      </div>
    </div>

    <SearchPosts />

    <div class="flex flex-wrap gap-2 mt-6">
      {categories.map((cat) => {
        const colorClass = categoryColors[cat!] || "bg-zinc-500/10 text-zinc-400 border-zinc-500/20 hover:bg-zinc-500/20";
        const count = posts.filter((p) => p.data.category === cat).length;
        return (
          <a
            href={`/blog?category=${encodeURIComponent(cat!)}`}
            class={`inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full border transition-colors ${colorClass}`}
          >
            {cat}
            <span class="text-[10px] opacity-60">{count}</span>
          </a>
        );
      })}
    </div>

    <div class="border-t border-zinc-200 dark:border-zinc-800 my-10"></div>
    <FeaturedPosts />
    <div class="border-t border-zinc-200 dark:border-zinc-800 my-12"></div>
    <RecentPosts />
  </div>
</MainLayout>
