---
import FormattedDate from "./FormattedDate.astro";

interface Props {
  title: string;
  desc: string;
  href: string;
  pubDate: Date;
  category?: string;
}

const { href, title, desc, pubDate, category } = Astro.props;

const categoryColors: Record<string, string> = {
  THM: "bg-emerald-500/15 text-emerald-400 border-emerald-500/30",
  "Malware Analysis": "bg-red-500/15 text-red-400 border-red-500/30",
  "Reverse Engineering": "bg-purple-500/15 text-purple-400 border-purple-500/30",
  XSS: "bg-amber-500/15 text-amber-400 border-amber-500/30",
  CEH: "bg-blue-500/15 text-blue-400 border-blue-500/30",
};

const colorClass =
  category && categoryColors[category]
    ? categoryColors[category]
    : "bg-zinc-500/15 text-zinc-400 border-zinc-500/30";
---

<li class="group">
  <a href={`/blog/${href}`} class="block p-4 -mx-4 rounded-lg transition-colors hover:bg-white/[0.03]">
    <div class="space-y-2 flex flex-col">
      <div class="flex items-center gap-3">
        <span class="font-light text-sm text-zinc-500">
          <FormattedDate date={pubDate} />
        </span>
        {category && (
          <span class={`text-xs font-medium px-2 py-0.5 rounded-full border ${colorClass}`}>
            {category}
          </span>
        )}
      </div>
      <h2 class="font-medium group-hover:text-lime-400 transition-colors" transition:name={title}>
        {title}
      </h2>
      <p class="font-light text-sm text-zinc-400 line-clamp-2">{desc}</p>
    </div>
  </a>
</li>
