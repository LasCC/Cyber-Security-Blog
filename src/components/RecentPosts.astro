---
import { getCollection } from "astro:content";
import PostCard from "./PostCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Exclude featured posts to avoid duplicates with FeaturedPosts section
const recentPosts = posts
  .filter((post) => !post.data.featured)
  .slice(0, 6);
---

<h2 class="text-2xl font-bold mb-6">Recent Posts</h2>
<ul class="space-y-1">
  {
    recentPosts.map((post) => (
      <PostCard
        title={post.data.title}
        desc={post.data.description}
        pubDate={post.data.pubDate}
        href={post.id}
        category={post.data.category}
      />
    ))
  }
</ul>
<div class="mt-6">
  <a
    href="/blog"
    class="inline-flex items-center text-gray-900 bg-linear-to-r from-lime-200 via-lime-400 to-lime-500 hover:bg-linear-to-br focus:ring-4 focus:outline-none focus:ring-lime-300 font-medium rounded-lg px-5 py-2.5 text-center transition-all"
  >
    Check all the Posts
    <svg
      width="6"
      height="10"
      viewBox="0 0 6 10"
      fill="none"
      class="inline-block ml-2"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M1 9L5 5L1 1"
        stroke="black"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>
</div>
