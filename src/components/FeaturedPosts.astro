---
import { getCollection } from "astro:content";
import FormattedDate from "./FormattedDate.astro";
import PostCard from "./PostCard.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.filter((post) => post.data.featured === true);
const heroPost = featuredPosts[0];
const restFeatured = featuredPosts.slice(1, 4);

const categoryColors: Record<string, string> = {
  THM: "bg-emerald-500/15 text-emerald-400 border-emerald-500/30",
  "Malware Analysis": "bg-red-500/15 text-red-400 border-red-500/30",
  "Reverse Engineering": "bg-purple-500/15 text-purple-400 border-purple-500/30",
  XSS: "bg-amber-500/15 text-amber-400 border-amber-500/30",
  CEH: "bg-blue-500/15 text-blue-400 border-blue-500/30",
};

const heroCategory = heroPost?.data.category;
const heroColorClass =
  heroCategory && categoryColors[heroCategory]
    ? categoryColors[heroCategory]
    : "bg-zinc-500/15 text-zinc-400 border-zinc-500/30";
---

<h2 class="text-2xl font-bold mb-6">Featured Posts</h2>

{heroPost && (
  <a href={`/blog/${heroPost.id}`} class="group block mb-8">
    <div class="relative overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800 bg-linear-to-br from-zinc-50 to-zinc-100 dark:from-zinc-900 dark:to-zinc-950 p-6 md:p-8 transition-all hover:border-zinc-300 dark:hover:border-zinc-700 hover:from-zinc-100/80 hover:to-zinc-200/80 dark:hover:from-zinc-800/80 dark:hover:to-zinc-900/80">
      <div class="absolute top-0 right-0 w-64 h-64 bg-lime-500/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 group-hover:bg-lime-500/10 transition-colors"></div>
      <div class="relative">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-sm text-zinc-500">
            <FormattedDate date={heroPost.data.pubDate} />
          </span>
          {heroCategory && (
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full border ${heroColorClass}`}>
              {heroCategory}
            </span>
          )}
        </div>
        <h3 class="text-2xl font-semibold mb-3 group-hover:text-lime-400 transition-colors" transition:name={heroPost.data.title}>
          {heroPost.data.title}
        </h3>
        <p class="text-zinc-600 dark:text-zinc-400 font-light leading-relaxed max-w-2xl">
          {heroPost.data.description}
        </p>
        <span class="inline-flex items-center gap-1 mt-4 text-sm text-lime-500 font-medium group-hover:gap-2 transition-all">
          Read article
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </span>
      </div>
    </div>
  </a>
)}

{restFeatured.length > 0 && (
  <ul class="space-y-1">
    {restFeatured.map((post) => (
      <PostCard
        title={post.data.title}
        desc={post.data.description}
        pubDate={post.data.pubDate}
        href={post.id}
        category={post.data.category}
      />
    ))}
  </ul>
)}
